# ════════════════════════════════════════════════════════════
# Söylemesi Bizden — Ortam Değişkenleri Şablonu
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun:
#   cp .env.example .env
# ════════════════════════════════════════════════════════════

# ─── Genel ──────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=SoylemesiBizden

# ─── Database (PostgreSQL) ──────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/soylemesi_db

# ─── Cache (Redis) ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Frontend (Next.js 16) ──────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Backend (NestJS / Go Microservices) ────────────────────
NEST_PORT=3001
GO_BACKEND_PORT=8080
GO_BACKEND_URL=http://localhost:8080

# ─── Search Engine (Rust) ───────────────────────────────────
RUST_SEARCH_PORT=8081
RUST_SEARCH_URL=http://localhost:8081

# ─── AI Engine (Python) ─────────────────────────────────────
AI_ENGINE_PORT=8090
AI_MODEL_PATH=./AI_Engine_Python/models

# ─── Auth ───────────────────────────────────────────────────
JWT_SECRET=change-this-to-min-32-chars-random-string
JWT_EXPIRES_IN=7d

# ─── External Services (opsiyonel) ──────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

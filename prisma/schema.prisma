// Sovereign Intelligence Engine - Data Schema
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Asset {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  location        String
  price           Decimal
  description     String   @db.Text
  
  // Intelligence Metrics
  sovereignIQ     Float    @default(0.0)
  roiAnnual       Float    @default(0.0)
  liquidityScore  String   // e.g., "AAA+"
  
  // Energy & Carbon Intelligence
  carbonGrade     String   @default("Pending") // A++, B, etc.
  carbonOffset    Float    @default(0.0)      // tCO2e
  solarPotential  Float    @default(0.0)      // MWh/Year
  
  // Legal & Verification
  isVerified      Boolean  @default(false)
  legalHash       String?  // Blockchain Seal Hash
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  advisorId       String
  advisor         Advisor  @relation(fields: [advisorId], references: [id])
}

model Advisor {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      String   @default("ANALYST")
  assets    Asset[]
}
